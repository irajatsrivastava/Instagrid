rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt']) 
        && data.keys().size() >= 4
        && data.uid == request.auth.uid 
        && data.email is string
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidExport(data) {
      return data.keys().hasAll(['userId', 'shortcode', 'url', 'commentCount', 'createdAt'])
        && data.keys().size() >= 5
        && data.userId == request.auth.uid
        && data.shortcode is string && data.shortcode.size() <= 50
        && data.url is string && data.url.size() <= 500
        && data.commentCount is number
        && data.createdAt == request.time;
    }

    // Match Blocks
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt'])
        && incoming().updatedAt == request.time;
    }

    match /exports/{exportId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidExport(incoming()) && isValidId(exportId);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
